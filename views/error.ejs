<% layout('layouts/main', { title: 'Error' }) %>
<div class="max-w-lg mx-auto px-4 py-20 text-center">
  <h1 class="text-6xl font-bold text-gray-300 mb-4"><%= typeof status !== 'undefined' ? status : '500' %></h1>
  <p class="text-xl text-gray-600 mb-8"><%= typeof message !== 'undefined' ? message : 'Something went wrong' %></p>
  <a href="/" class="text-indigo-600 hover:underline">Go Home</a>
</div>
