<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-left">
      <tr>
        <th class="px-4 py-3 font-medium">ID</th>
        <th class="px-4 py-3 font-medium">Username</th>
        <th class="px-4 py-3 font-medium">Email</th>
        <th class="px-4 py-3 font-medium">Role</th>
        <th class="px-4 py-3 font-medium">Active</th>
        <th class="px-4 py-3 font-medium">Actions</th>
      </tr>
    </thead>
    <tbody id="usersTable"></tbody>
  </table>
  <div id="usersSpinner" class="text-center py-6 text-gray-400">Loading...</div>
</div>
<script>
let upage = 1, uloading = false, umore = true;
async function loadUsers() {
  if (uloading || !umore) return;
  uloading = true;
  try {
    const res = await fetch(`/api/admin/users?page=${upage}&limit=20`);
    const data = await res.json();
    const tbody = document.getElementById('usersTable');
    data.users.forEach(u => {
      const tr = document.createElement('tr');
      tr.className = 'border-t hover:bg-gray-50';
      tr.innerHTML = `
        <td class="px-4 py-3">${u.id}</td>
        <td class="px-4 py-3 font-medium">${u.username}</td>
        <td class="px-4 py-3 text-gray-500">${u.email}</td>
        <td class="px-4 py-3"><span class="px-2 py-0.5 rounded text-xs ${u.role === 'admin' ? 'bg-orange-100 text-orange-700' : 'bg-gray-100 text-gray-600'}">${u.role}</span></td>
        <td class="px-4 py-3">${u.is_active ? '<span class="text-green-600">Active</span>' : '<span class="text-red-500">Disabled</span>'}</td>
        <td class="px-4 py-3">
          <button class="toggle-btn text-sm ${u.is_active ? 'text-red-600' : 'text-green-600'} hover:underline" data-user-id="${u.id}">${u.is_active ? 'Disable' : 'Enable'}</button>
        </td>
      `;
      tbody.appendChild(tr);
    });
    umore = data.users.length === 20;
    upage++;
  } catch (err) { console.error(err); }
  finally { uloading = false; document.getElementById('usersSpinner').classList.add('hidden'); }
}
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('.toggle-btn');
  if (!btn) return;
  try {
    const res = await fetch(`/api/admin/users/${btn.dataset.userId}/toggle`, { method: 'PUT' });
    if (res.ok) location.reload();
  } catch (err) { console.error(err); }
});
window.addEventListener('scroll', () => {
  if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 300) loadUsers();
});
loadUsers();
</script>
