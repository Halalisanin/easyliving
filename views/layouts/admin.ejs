<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Admin — EasyLiving</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/admin" class="text-xl font-bold text-orange-600">Admin Panel</a>
      <div class="flex items-center gap-4 text-sm">
        <a href="/admin/users" class="hover:text-orange-600 transition">Users</a>
        <a href="/feed" class="hover:text-indigo-600 transition">Back to Feed</a>
        <button id="logoutBtn" class="text-red-500 hover:text-red-700 transition">Logout</button>
      </div>
    </div>
  </nav>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <%- body %>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
